# ──────────────────────────────────────────────────────────────────────────────
# PortPane by ShackDesk — RSA Public Key
# Project  : https://github.com/Computer-Tsu/shackdesk-portpane
# Author   : Mark McDow (N4TEK) — My Computer Guru LLC
# Owner    : My Computer Guru LLC
#
# FORMAT: .NET RSA XML (RSA.ToXmlString / RSA.FromXmlString)
# Note   : This key is in .NET XML format, not PEM. The .pem extension is kept
#          for consistency with .gitignore rules. Embedded in LicenseService.cs.
#
# PURPOSE
# This file contains the RSA-2048 public key used by PortPane to verify:
#   1. License key signatures  — validates commercial license keys offline
#   2. Update manifest signatures — verifies update packages before installing
#
# SAFE TO SHARE — THIS IS A PUBLIC KEY
# This is the PUBLIC half of the RSA key pair. Sharing it is normal and
# expected. It cannot be used to generate or forge license keys.
#
# ALGORITHM  : RSA-2048, SHA-256, PKCS1 padding
# KEY FORMAT : .NET RSA XML (ToXmlString / FromXmlString)
# ──────────────────────────────────────────────────────────────────────────────

<RSAKeyValue><Modulus></Modulus><Exponent>AQAB</Exponent></RSAKeyValue>
