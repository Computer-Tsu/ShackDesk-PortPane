  <data name="AboutVersion"        xml:space="preserve"><value>Version {0}</value></data>
  <data name="AboutAuthor"         xml:space="preserve"><value>By {0} ({1})</value></data>
  <data name="AboutLicense"        xml:space="preserve"><value>Licensed under GPL v3 / Commercial</value></data>
