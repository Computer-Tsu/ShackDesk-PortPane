<Window x:Class="PortPane.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PortPane"
        xmlns:views="clr-namespace:PortPane.Views"
        Title="About PortPane"
        Width="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        ShowInTaskbar="False">

    <StackPanel Margin="24,20">

        <!-- App logo — double-click for easter egg -->
        <Border x:Name="LogoBorder"
                Background="Transparent"
                CornerRadius="12"
                Width="72" Height="72"
                HorizontalAlignment="Center"
                Margin="0,0,0,12"
                Cursor="Hand"
                MouseLeftButtonDown="Logo_MouseDown"
                ToolTip="Double-click for a surprise">
            <Image Source="pack://application:,,,/Assets/AppLogo.png"
                   Width="72" Height="72"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- Easter egg canvas (hidden until triggered) -->
        <views:EasterEggControl x:Name="EasterEgg"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,8"
                                Visibility="Collapsed"/>

        <!-- App name & version -->
        <TextBlock Text="{x:Static local:BrandingInfo.FullName}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,2,0,16">
            <Run Text="Version "/>
            <Run Text="{x:Static local:BrandingInfo.Version}"/>
        </TextBlock>

        <!-- Author -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                Padding="14,10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="13">
                    <Run Text="By "/>
                    <Run Text="{x:Static local:BrandingInfo.AuthorName}" FontWeight="SemiBold"/>
                    <Run Text=" · "/>
                    <Run Text="{x:Static local:BrandingInfo.AuthorCallsign}"
                         Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                </TextBlock>
                <TextBlock Text="{x:Static local:BrandingInfo.AuthorCompany}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- License tier (shown only for paid licensees) -->
        <TextBlock x:Name="LicenseeBlock"
                   Foreground="{StaticResource RadioModeBrush}"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"
                   Margin="0,0,0,8"/>

        <!-- Support the author (shown only on Free tier) -->
        <TextBlock x:Name="SupportBlock"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Text="Enjoying PortPane? Consider supporting the author."
                   Margin="0,0,0,4"/>

        <!-- Links -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,16">
            <TextBlock Margin="0,0,12,0">
                <Hyperlink Click="GitHub_Click" Foreground="{StaticResource AccentBrush}">
                    View on GitHub
                </Hyperlink>
            </TextBlock>
            <TextBlock>
                <Hyperlink Click="Support_Click" Foreground="{StaticResource AccentBrush}">
                    Get Support
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Support ID -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Support ID"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="SupportIdText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,2,0,6"/>
                <TextBlock Text="This random ID helps match your support request to anonymous app reports if telemetry is enabled."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>
                <Button Content="Copy Support ID"
                        Click="CopySupportId_Click"
                        Height="28"
                        Padding="12,0"
                        Background="{StaticResource SurfaceElevatedBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <TextBlock Text="{x:Static local:BrandingInfo.LicenseType}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11"
                   HorizontalAlignment="Center"/>

        <!-- Close -->
        <Button Content="Close"
                Click="Close_Click"
                Height="36"
                Margin="0,14,0,0"
                Padding="24,0"
                FontSize="13"
                Background="{StaticResource SurfaceElevatedBrush}"
                Foreground="{StaticResource TextPrimaryBrush}"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Center"
                ToolTip="Close this dialog"/>
    </StackPanel>
</Window>
