<Window x:Class="PortPane.Views.TelemetryDataViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="View Collected Data — PortPane"
        Width="560" Height="440"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Data PortPane Has Collected"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                       Text="This is exactly what would be sent if you choose to share data. No personal information is included. Unrecognized devices are highlighted."/>
        </StackPanel>

        <!-- Report list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ReportList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="5" Padding="12,8" Margin="0,3">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding EventName}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DockPanel>
                                <TextBlock Text="{Binding JsonPayload}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           MaxHeight="120"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyLabel"
                   Grid.Row="1"
                   Text="No collected data. PortPane has not recorded any pending reports."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Send This Report"
                    Click="Send_Click"
                    MinHeight="36" Padding="14,0"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,8,0"
                    ToolTip="Send the pending report to the developer now"/>
            <Button Content="Clear Data"
                    Click="Clear_Click"
                    MinHeight="36" Padding="14,0"
                    Background="{StaticResource SurfaceElevatedBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,8,0"
                    ToolTip="Delete all collected data locally"/>
            <Button Content="Close"
                    Click="Close_Click"
                    MinHeight="36" Padding="14,0"
                    Background="{StaticResource SurfaceElevatedBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Close this window"/>
        </StackPanel>
    </Grid>
</Window>
