<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         COLOR PALETTE — Dark theme, high-contrast, accessible.
         Uses SystemColors for High Contrast mode compatibility.
         Never hardcode colors that override accessibility themes.
    ══════════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="WindowBackgroundBrush"   Color="#1C1C1E"/>
    <SolidColorBrush x:Key="SurfaceBrush"            Color="#2C2C2E"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush"    Color="#3A3A3C"/>
    <SolidColorBrush x:Key="ChromeBackgroundBrush"   Color="#111113"/>
    <SolidColorBrush x:Key="BorderBrush"             Color="#48484A"/>
    <SolidColorBrush x:Key="AccentBrush"             Color="#0A84FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush"        Color="#409CFF"/>
    <SolidColorBrush x:Key="RadioModeBrush"          Color="#30D158"/>
    <SolidColorBrush x:Key="RadioBadgeBrush"         Color="#FF9F0A"/>
    <SolidColorBrush x:Key="GhostBrush"              Color="#636366"/>
    <SolidColorBrush x:Key="DangerBrush"             Color="#FF453A"/>
    <SolidColorBrush x:Key="UpdateBannerBrush"       Color="#1D3557"/>
    <SolidColorBrush x:Key="DragStripBrush"          Color="#0D0D0F"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush"        Color="#EBEBF5"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"      Color="#8E8E93"/>
    <SolidColorBrush x:Key="TextAccentBrush"         Color="#0A84FF"/>
    <SolidColorBrush x:Key="PortNameBrush"           Color="#64D2FF"/>
    <SolidColorBrush x:Key="DefaultDeviceBrush"      Color="#FFD60A"/>

    <!-- Converters -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ═══════════════════════════════════════════════════════════════
         TYPOGRAPHY
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="BodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin"       Value="0,8,0,3"/>
        <Setter Property="TextTransform" Value="Uppercase"/>
    </Style>

    <Style x:Key="DefaultDeviceLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="FontSize"   Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource DefaultDeviceBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="PortNameStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="FontFamily"   Value="Consolas, Courier New"/>
        <Setter Property="FontSize"     Value="15"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="{StaticResource PortNameBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinWidth"     Value="52"/>
    </Style>

    <Style x:Key="GhostTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="Foreground"    Value="{StaticResource GhostBrush}"/>
        <Setter Property="FontStyle"     Value="Italic"/>
        <Setter Property="TextTrimming"  Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="FooterStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStyle}">
        <Setter Property="FontSize"  Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         DRAG STRIP
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="DragStripStyle" TargetType="Border">
        <Setter Property="Height"           Value="8"/>
        <Setter Property="Background"       Value="{StaticResource DragStripBrush}"/>
        <Setter Property="Cursor"           Value="SizeAll"/>
        <Setter Property="ToolTip"          Value="Drag to move window"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CHROME OVERLAY (title bar, menu, window controls)
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="ChromeBarStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ChromeBackgroundBrush}"/>
        <Setter Property="Padding"    Value="4,2"/>
    </Style>

    <Style x:Key="ChromeButtonStyle" TargetType="Button">
        <Setter Property="Background"           Value="Transparent"/>
        <Setter Property="Foreground"           Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="Width"                Value="44"/>
        <Setter Property="Height"               Value="32"/>
        <Setter Property="FontSize"             Value="12"/>
        <Setter Property="Cursor"               Value="Hand"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ChromeButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         PROFILE SWITCH BUTTON — Primary UI action
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="ProfileSwitchButtonStyle" TargetType="Button">
        <Setter Property="Height"           Value="48"/>
        <Setter Property="MinWidth"         Value="200"/>
        <Setter Property="FontSize"         Value="16"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Background"       Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground"       Value="White"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="ToolTip"          Value="{Binding ProfileButtonTooltip}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="16,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- Radio mode: green -->
        <Style.Triggers>
            <DataTrigger Binding="{Binding Audio.IsRadioMode}" Value="True">
                <Setter Property="Background" Value="{StaticResource RadioModeBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         DEVICE CARDS
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="DeviceCardStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="5"/>
        <Setter Property="Padding"         Value="10,7"/>
        <Setter Property="Margin"          Value="0,2"/>
    </Style>

    <Style x:Key="RadioDeviceCardStyle" TargetType="Border" BasedOn="{StaticResource DeviceCardStyle}">
        <Setter Property="BorderBrush"  Value="{StaticResource RadioBadgeBrush}"/>
        <Setter Property="BorderThickness" Value="1,1,1,2"/>
    </Style>

    <Style x:Key="GhostDeviceCardStyle" TargetType="Border" BasedOn="{StaticResource DeviceCardStyle}">
        <Setter Property="Opacity"      Value="0.45"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         BUTTONS (general)
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="CopyButtonStyle" TargetType="Button">
        <Setter Property="MinHeight"        Value="44"/>
        <Setter Property="MinWidth"         Value="44"/>
        <Setter Property="Padding"          Value="8,4"/>
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="Background"       Value="{StaticResource SurfaceElevatedBrush}"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="ToolTip"          Value="Copy port name to clipboard"/>
    </Style>

    <Style x:Key="PuttyButtonStyle" TargetType="Button" BasedOn="{StaticResource CopyButtonStyle}">
        <Setter Property="ToolTip" Value="Open in PuTTY with selected baud rate"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         UPDATE BANNER
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="UpdateBannerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource UpdateBannerBrush}"/>
        <Setter Property="Padding"    Value="10,6"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         MENU (revealed chrome)
    ══════════════════════════════════════════════════════════════════ -->

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource ChromeBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         RADIO BADGE
    ══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="RadioBadgeStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource RadioBadgeBrush}"/>
        <Setter Property="CornerRadius"    Value="3"/>
        <Setter Property="Padding"         Value="4,1"/>
        <Setter Property="Margin"          Value="4,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="ToolTip"         Value="Radio interface — compatible with digital mode software"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SCROLLVIEWER
    ══════════════════════════════════════════════════════════════════ -->

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</ResourceDictionary>
